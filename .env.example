# Web server port exposed by the container.
PORT=3000

# Single external SOCKS5 proxy port.
# All SOCKS accounts share this port; the username determines the proxy node.
SOCKS_PORT=9999

# Persistent SQLite database path inside the container.
RUST_PROXY_MANAGER_DB=/data/proxy_manager.db

# Persistent data directory for generated Mihomo config and runtime files.
RUST_PROXY_MANAGER_DATA_DIR=/data

# Path to the Mihomo binary inside the container image.
MIHOMO_BINARY=/usr/local/bin/mihomo
